{
  "expo": {
    "name": "QAZA Workspace",
    "slug": "qaza-workspace",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-icon.png",
    "scheme": "qazaworkspace",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "notification": {
      "icon": "./assets/adaptive-icon.png",
      "color": "#4E7A28"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.aure.qazaworkspace",
      "label": "QAZA Workspace",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo.png"
    },
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "0bf71ce5-a18f-41d0-9539-0ae0341dfaaf"
      }
    },
    "owner": "aurex",
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}